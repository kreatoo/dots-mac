#!/bin/sh
# Hermes PPPoE recovery - runs as background monitor after sysupgrade
set -eu

LOG_TAG="hermes-pppoe-recovery"
LOG_FILE="${HERMES_PPPOE_RECOVERY_LOG_FILE:-/tmp/hermes-pppoe-recovery.log}"
READY_TIMEOUT="${HERMES_PPPOE_READY_TIMEOUT:-120}"
TOTAL_TIMEOUT="${HERMES_PPPOE_TOTAL_TIMEOUT:-600}"
BACKOFF_INITIAL="${HERMES_PPPOE_BACKOFF_INITIAL:-10}"
BACKOFF_MAX="${HERMES_PPPOE_BACKOFF_MAX:-60}"
WAN_IFACE="${HERMES_WAN_IFACE:-wan}"
NETWORK_RESTART_CMD="${HERMES_NETWORK_RESTART_CMD:-/etc/init.d/network restart}"
STATE_FILE="${HERMES_PPPOE_STATE_FILE:-/etc/hermes/pppoe-recovery.done}"

timestamp() {
  date '+%Y-%m-%dT%H:%M:%S%z'
}

log() {
  msg="$1"
  line="$(timestamp) $msg"
  printf '%s\n' "$line" >> "$LOG_FILE"
  if [ -t 1 ] || [ "${HERMES_PPPOE_VERBOSE:-0}" = "1" ]; then
    printf '%s\n' "$line" >&2
  fi
  logger -t "$LOG_TAG" "$msg" >/dev/null 2>&1 || true
}

wan_status() {
  ubus call "network.interface.$WAN_IFACE" status 2>/dev/null || true
}

wan_is_up() {
  status="$1"
  printf '%s' "$status" | grep -Eq '"up"[[:space:]]*:[[:space:]]*true'
}

wan_auth_failed() {
  status="$1"
  printf '%s' "$status" | grep -Eqi 'auth[-_ ]?failed|AUTH_FAILED|authentication failed'
}

wait_for_netifd() {
  waited=0
  while [ "$waited" -lt "$READY_TIMEOUT" ]; do
    if ubus call "network.interface.$WAN_IFACE" status >/dev/null 2>&1; then
      log "netifd ready after ${waited}s"
      return 0
    fi
    sleep 1
    waited=$((waited + 1))
  done
  log "netifd not ready within ${READY_TIMEOUT}s, continuing anyway"
  return 0
}

run_network_restart() {
  log "restarting network service"
  sh -c "$NETWORK_RESTART_CMD" >/dev/null 2>&1 || true
}

bounce_interface() {
  log "bouncing interface $WAN_IFACE"
  ifdown "$WAN_IFACE" >/dev/null 2>&1 || true
  sleep 2
  ifup "$WAN_IFACE" >/dev/null 2>&1 || true
}

mkdir -p "$(dirname "$LOG_FILE")"
log "starting recovery for interface=$WAN_IFACE (total timeout=${TOTAL_TIMEOUT}s)"

# Wait for netifd with extended timeout
wait_for_netifd

start_epoch=$(date +%s)
deadline=$((start_epoch + TOTAL_TIMEOUT))
attempt=1
backoff="$BACKOFF_INITIAL"
consecutive_auth_failures=0

while :; do
  now=$(date +%s)
  if [ "$now" -ge "$deadline" ]; then
    log "timed out after ${TOTAL_TIMEOUT}s without WAN recovery"
    exit 1
  fi

  status=$(wan_status)

  if wan_is_up "$status"; then
    mkdir -p "$(dirname "$STATE_FILE")"
    : > "$STATE_FILE"
    log "success: WAN is up on attempt $attempt"
    exit 0
  fi

  if wan_auth_failed "$status"; then
    consecutive_auth_failures=$((consecutive_auth_failures + 1))
    log "detected auth-failed state (consecutive=$consecutive_auth_failures)"

    # After 3 consecutive auth failures, take action
    if [ "$consecutive_auth_failures" -ge 3 ]; then
      log "auth failed $consecutive_auth_failures times, restarting network"
      run_network_restart
      consecutive_auth_failures=0
      sleep 5
    fi
  else
    consecutive_auth_failures=0
    log "WAN still down on attempt $attempt"
  fi

  # Also do a full network restart every 60 seconds as safety net
  if [ "$attempt" -gt 1 ] && [ $((attempt % 6)) -eq 0 ]; then
    log "periodic network restart (attempt $attempt)"
    run_network_restart
    sleep 5
  fi

  bounce_interface

  sleep "$backoff"
  if [ "$backoff" -lt "$BACKOFF_MAX" ]; then
    next_backoff=$((backoff * 2))
    if [ "$next_backoff" -gt "$BACKOFF_MAX" ]; then
      backoff="$BACKOFF_MAX"
    else
      backoff="$next_backoff"
    fi
  fi
  attempt=$((attempt + 1))
done
